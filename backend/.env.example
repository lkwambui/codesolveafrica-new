# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_URL=mysql://root:password@localhost:3306/codesolveafrica

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-this-to-a-strong-password

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend
RESEND_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Cookie (for signed cookies)
COOKIE_SECRET=change-this-to-another-random-64-char-string

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
